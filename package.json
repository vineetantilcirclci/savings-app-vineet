{
  "name": "savings-app",
  "version": "1.0.0",
  "description": "A minimalistic spending tracker app",
  "main": "index.html",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src",
    "test:e2e:stable": "playwright test --config=playwright.config.js",
    "test:e2e:full": "playwright test --config=playwright.config.js",
    "test:e2e:visual": "playwright test --config=playwright.visual.config.js",
    "test:e2e:couchdb": "playwright test --config=playwright.couchdb.config.js",
    "test:perf": "playwright test --config=playwright.perf.config.js",
    "cov:e2e:report": "nyc report",
    "cov:e2e:stable:publish": "codecov -f coverage/lcov.info -F e2e-stable",
    "cov:e2e:full:publish": "codecov -f coverage/lcov.info -F e2e-full",
    "cov:unit:publish": "codecov -f coverage/lcov.info -F unit"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.0.4",
    "@vitest/ui": "^1.0.4",
    "jsdom": "^23.0.1",
    "vite": "^5.0.8",
    "vitest": "^1.0.4"
  }
}
