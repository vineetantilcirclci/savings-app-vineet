{
  "name": "savings-app",
  "version": "1.0.0",
  "description": "A minimalistic spending tracker app",
  "main": "index.html",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .js,.jsx --max-warnings=0",
    "test:e2e:stable": "playwright test --project=chromium",
    "test:e2e:full": "playwright test",
    "test:e2e:visual": "playwright test --grep @visual",
    "test:perf": "playwright test --grep @perf",
    "cov:e2e:report": "nyc report || true",
    "cov:e2e:stable:publish": "codecov -F e2e-stable || true",
    "cov:e2e:full:publish": "codecov -F e2e-full || true",
    "cov:unit:publish": "codecov -F unit || true"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.0.4",
    "@vitest/ui": "^1.0.4",
    "jsdom": "^23.0.1",
    "vite": "^5.0.8",
    "vitest": "^1.0.4",
    "@playwright/test": "^1.40.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2"
  }
}
